# Variables d'environnement pour la plateforme de documentation
# Copiez ce fichier vers .env et remplissez les valeurs

# URL de votre projet Supabase
# Trouvez-la dans : Dashboard Supabase > Settings > API
PUBLIC_SUPABASE_URL=https://votre-projet.supabase.co

# Clé anonyme (anon key) de Supabase
# Trouvez-la dans : Dashboard Supabase > Settings > API
PUBLIC_SUPABASE_ANON_KEY=votre-clé-anon-supabase

# URL canonique du site
SITE_URL=https://zodev.live/

# Code HTML facultatif fourni par Google Search Console
PUBLIC_GOOGLE_SITE_VERIFICATION=votre-code-google-search-console

# Ne pas commiter le fichier .env dans git
