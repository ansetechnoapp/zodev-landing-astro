---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import dataUser from "../data/User.json";
import { LandingClient } from "../components/reactJS/LandingClient";

const projects = (await getCollection("work"))
  .sort((a, b) => b.data.number - a.data.number)
  .slice(0, 4);

const pageTitle = `${dataUser.firstName} ${dataUser.lastName} | Développeur web & mobile`;
const pageDescription =
  "Landing premium de {firstName} {lastName}, développeur web et mobile basé à {city}. Découvrez une sélection de projets, sa stack principale et un accès clair vers le portfolio complet sur my.zodev.live.";
const description = pageDescription
  .replace("{firstName}", dataUser.firstName)
  .replace("{lastName}", dataUser.lastName)
  .replace("{city}", dataUser.address.city);
---

<Layout title={pageTitle} description={description} image="/assets/social-preview.jpg" type="website">
  <LandingClient client:load projects={projects} />
</Layout>
