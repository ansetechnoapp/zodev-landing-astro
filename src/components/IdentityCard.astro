---
---

<div class="identity-card">
  <!-- Vertical sidebar with social links -->
  <div class="identity-sidebar">
    <div class="sidebar-line" aria-hidden="true"></div>
    <div class="sidebar-socials">
      <slot name="social" />
    </div>
    <div class="sidebar-line" aria-hidden="true"></div>
  </div>

  <!-- Main identity block -->
  <div class="identity-main">
    <div class="identity-header">
      <div class="identity-photo">
        <div class="photo-mask">
          <slot name="photo" />
        </div>
        <div class="photo-accent-bar" aria-hidden="true"></div>
      </div>

      <div class="identity-name">
        <h1 class="name-display">
          <span class="name-first">KEVIN</span>
          <span class="name-last">OTTY</span>
        </h1>
        <p class="identity-role">Développeur Web & Mobile</p>
        <div class="name-rule" aria-hidden="true"></div>
      </div>
    </div>

    <div class="identity-stats">
      <div class="stat-item">
        <span class="stat-number">7+</span>
        <span class="stat-label">Ans d'exp.</span>
      </div>
      <div class="stat-item">
        <span class="stat-number">16+</span>
        <span class="stat-label">Projets</span>
      </div>
      <div class="stat-item">
        <span class="stat-number">N+</span>
        <span class="stat-label">Clients</span>
      </div>
    </div>

    <div class="identity-techs">
      <span class="tech-pill">React</span>
      <span class="tech-pill">React Native</span>
      <span class="tech-pill">Astro</span>
      <span class="tech-pill">Node.js</span>
    </div>

    <div class="identity-about">
      <p class="about-text">
        Expert en création d'expériences numériques intuitives et scalables.
      </p>
      <div class="about-footer">
        <span class="location">📍 Cotonou, Bénin</span>
        <span class="status-badge">Disponible pour Freelance</span>
      </div>
    </div>
  </div>
</div>

<style>
  /* ===== Identity Card Styles ===== */
  .identity-card {
    display: grid;
    grid-template-columns: 48px 1fr;
    gap: 0;
    width: 100%;
    max-width: 540px;
    height: 100%;
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(100, 116, 162, 0.12);
    border-radius: 1.5rem;
    overflow: hidden;
    position: relative;
    animation: cardReveal 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards, floatCard 6s ease-in-out infinite alternate;
    opacity: 0;
    transition: 
      border-color 0.4s ease, 
      box-shadow 0.4s ease, 
      transform 0.5s cubic-bezier(0.16, 1, 0.3, 1), 
      background 0.4s ease;
    transform-style: preserve-3d;
    will-change: transform, box-shadow;
  }

  .identity-card:hover {
    border-color: rgba(20, 184, 166, 0.25);
    background: rgba(255, 255, 255, 0.08);
    box-shadow:
      0 32px 64px rgba(0, 0, 0, 0.15),
      0 0 0 1px rgba(20, 184, 166, 0.08),
      0 0 80px -20px rgba(20, 184, 166, 0.08);
  }

  :root.theme-dark .identity-card {
    background: rgba(20, 25, 37, 0.5);
    border-color: rgba(100, 116, 162, 0.15);
  }

  /* Vertical Sidebar */
  .identity-sidebar {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding: 1.5rem 0;
    border-right: 1px solid rgba(100, 116, 162, 0.1);
    animation: sidebarReveal 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.3s forwards;
    opacity: 0;
  }

  .sidebar-line {
    width: 1px;
    flex: 1;
    background: linear-gradient(180deg, transparent, var(--accent-teal), transparent);
    opacity: 0.3;
    transition: opacity 0.4s ease;
  }

  .identity-card:hover .sidebar-line {
    opacity: 0.6;
  }

  .sidebar-socials {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    align-items: center;
  }

  .sidebar-socials :global(.hero-media-social-nav) {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    align-items: center;
    margin-top: 0;
    padding: 0;
    background: none;
    border-radius: 0;
    box-shadow: none;
  }

  .sidebar-socials :global(.social-link) {
    width: 32px;
    height: 32px;
    padding: 0;
    border-radius: 8px;
    background: transparent;
    border: 1px solid rgba(100, 116, 162, 0.15);
    color: var(--gray-400);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    box-shadow: none;
  }

  .sidebar-socials :global(.social-link:hover) {
    background: var(--accent-teal);
    border-color: var(--accent-teal);
    color: white;
    transform: scale(1.1);
    box-shadow: 0 4px 12px rgba(20, 184, 166, 0.3);
  }

  .sidebar-socials :global(.social-link svg),
  .sidebar-socials :global(.social-link .icon) {
    width: 16px;
    height: 16px;
  }

  /* Identity Main */
  .identity-main {
    display: flex;
    flex-direction: column;
  }

  .identity-header {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1.5rem 1.5rem 1.25rem;
  }

  /* Photo Treatment */
  .identity-photo {
    position: relative;
    flex-shrink: 0;
  }

  .photo-mask {
    position: relative;
    width: 120px;
    height: 120px;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: 1rem;
    animation: photoReveal 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.2s forwards;
    opacity: 0;
    clip-path: inset(100% 0 0 0);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
  }

  .photo-mask :global(.hero-image-modern) {
    width: 100%;
    height: 100%;
  }

  .photo-mask :global(.image-wrapper) {
    width: 100%;
    height: 100%;
  }

  .photo-mask :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    border-radius: 0;
    filter: contrast(1.05) saturate(0.9);
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), filter 0.4s ease;
    box-shadow: none;
  }

  .identity-card:hover .photo-mask :global(img) {
    transform: scale(1.04);
    filter: contrast(1.05) saturate(1.1);
  }

  .photo-accent-bar {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--accent-purple), var(--accent-teal), var(--accent-electric));
    border-radius: 0 0 1rem 1rem;
    opacity: 0.8;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .identity-card:hover .photo-accent-bar {
    transform: scaleX(1);
  }

  /* Name Typography */
  .identity-name {
    padding: 0;
    flex: 1;
  }

  .name-display {
    font-family: var(--font-brand, 'Outfit', sans-serif);
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 800;
    line-height: 0.9;
    letter-spacing: -0.04em;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.1em;
    animation: nameReveal 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.5s forwards;
    opacity: 0;
  }

  .name-first {
    display: block;
    color: var(--gray-0);
    opacity: 0.85;
    font-weight: 700;
    font-size: 0.65em;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.1);
  }

  .name-last {
    display: block;
    background: linear-gradient(135deg, var(--accent-teal) 0%, var(--accent-electric) 50%, var(--accent-purple) 100%);
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-size: 200% 200%;
    animation: gradientShift 6s ease-in-out infinite;
  }

  .name-rule {
    width: 0;
    height: 2px;
    background: var(--accent-teal);
    margin-top: 1rem;
    border-radius: 1px;
    animation: ruleReveal 0.5s cubic-bezier(0.16, 1, 0.3, 1) 0.7s forwards;
    opacity: 0;
    transition: width 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .identity-card:hover .name-rule {
    width: 80px;
  }

  /* Role text */
  .identity-role {
    font-size: 0.85rem;
    color: var(--gray-200);
    letter-spacing: 0.02em;
    margin: 0.35rem 0 0;
    font-weight: 600;
  }

  /* Stats row */
  .identity-stats {
    display: flex;
    gap: 1rem;
    padding: 0.75rem 1.5rem;
    border-top: 1px solid rgba(100, 116, 162, 0.1);
    animation: nameReveal 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.8s forwards;
    opacity: 0;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex: 1;
  }

  .stat-number {
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--accent-teal);
    line-height: 1;
  }

  .stat-label {
    font-size: 0.7rem;
    color: var(--gray-200);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-top: 0.3rem;
    font-weight: 600;
  }

  /* Tech pills */
  .identity-techs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    padding: 0.75rem 1.5rem 1.25rem;
    animation: nameReveal 0.6s cubic-bezier(0.16, 1, 0.3, 1) 1s forwards;
    opacity: 0;
  }

  .tech-pill {
    font-size: 0.65rem;
    font-weight: 600;
    padding: 0.25rem 0.6rem;
    border-radius: 1rem;
    background: rgba(20, 184, 166, 0.1);
    border: 1px solid rgba(20, 184, 166, 0.2);
    color: var(--accent-teal);
    letter-spacing: 0.02em;
    transition: all 0.3s ease;
  }

  .tech-pill:hover {
    background: rgba(20, 184, 166, 0.2);
    border-color: rgba(20, 184, 166, 0.4);
    transform: translateY(-1px);
  }

  /* Identity About Section */
  .identity-about {
    padding: 0.75rem 1.5rem 1.75rem;
    border-top: 1px solid rgba(100, 116, 162, 0.1);
    animation: nameReveal 0.6s cubic-bezier(0.16, 1, 0.3, 1) 1.2s forwards;
    opacity: 0;
  }

  .about-text {
    font-size: 0.85rem;
    line-height: 1.6;
    color: var(--gray-200);
    margin: 0 0 1.25rem;
    font-weight: 500;
  }

  .about-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.75rem;
  }

  .location {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--gray-200);
  }

  .status-badge {
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.3rem 0.8rem;
    border-radius: 1rem;
    background: rgba(34, 197, 94, 0.15);
    color: #16a34a;
    border: 1px solid rgba(22, 163, 74, 0.3);
  }

  /* Identity Card Animations */
  @keyframes cardReveal {
    from { opacity: 0; transform: translateY(30px) scale(0.97); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  @keyframes sidebarReveal {
    from { opacity: 0; transform: translateX(-10px); }
    to { opacity: 1; transform: translateX(0); }
  }

  @keyframes photoReveal {
    from { opacity: 0; clip-path: inset(100% 0 0 0); }
    to { opacity: 1; clip-path: inset(0 0 0 0); }
  }

  @keyframes nameReveal {
    from { opacity: 0; transform: translateY(15px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes ruleReveal {
    from { opacity: 0; width: 0; }
    to { opacity: 1; width: 40px; }
  }

  @keyframes gradientShift {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  @keyframes floatCard {
    0% { transform: translateY(0); }
    100% { transform: translateY(-15px); }
  }

  /* Responsive Design */
  @media (max-width: 1024px) {
    .identity-card {
      width: 100%;
      max-width: 360px;
    }
    .name-display {
      font-size: clamp(1.6rem, 3.5vw, 2rem);
    }
    .sidebar-socials,
    .sidebar-socials :global(.hero-media-social-nav) {
      flex-direction: row;
    }
  }

  @media (max-width: 768px) {
    .identity-card {
      grid-template-columns: 1fr;
      width: 100%;
      max-width: 420px;
    }
    .identity-sidebar {
      flex-direction: row;
      border-right: none;
      border-top: 1px solid rgba(100, 116, 162, 0.1);
      padding: 1rem 1.5rem;
      order: 3;
    }
    .sidebar-line {
      width: auto;
      height: 1px;
      flex: 1;
    }
    .sidebar-socials {
      flex-direction: row;
    }
    .identity-header {
      flex-direction: column;
      text-align: center;
      padding: 1.5rem 1.5rem 1rem;
    }
    .identity-photo {
      margin: 0 0 1rem 0;
    }
    .name-display {
      font-size: clamp(1.8rem, 8vw, 2.5rem);
      text-align: center;
      align-items: center;
    }
    .name-rule {
      margin-left: auto;
      margin-right: auto;
    }
  }

  @media (max-width: 480px) {
    .identity-card {
      max-width: 100%;
    }
    .identity-header {
      padding: 1rem 1rem 0.75rem;
    }
    .identity-photo {
      margin: 0 0 0.75rem 0;
    }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .identity-card,
    .identity-sidebar,
    .photo-mask,
    .name-display,
    .name-rule {
      animation: none;
      opacity: 1;
      clip-path: none;
      transform: none;
    }
    .name-rule {
      width: 40px;
    }
    .name-last {
      animation: none;
    }
  }
</style>
