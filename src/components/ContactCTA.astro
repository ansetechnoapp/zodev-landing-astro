---
import CallToAction from "./CallToAction.astro";
import Icon from "./reactJS/Icon";
import { getLangFromCookies, getTranslations } from "../i18n/index";
import dataUser from "../data/User.json";
const lang = getLangFromCookies(Astro.cookies);
const i18n = getTranslations(lang);

const copyEmailLabel = i18n.contactCTA.copyEmail;
const copiedLabel = i18n.contactCTA.copied;
---

<aside class="contact-cta-premium" id="contact-cta">
  <div class="bg-noise"></div>
  <div class="background-blobs">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>
  </div>
  
  <div class="premium-card-wrapper" id="premium-card">
    <div class="premium-container">
      <div class="spotlight"></div>
      <div class="card-glass-shine"></div>
      
      <div class="content-grid">
        <!-- Section Info (Gauche) -->
        <div class="contact-info-side">
          <div class="status-badge" data-aos="fade-right">
            <span class="dot"></span>
            <span class="status-text">{i18n.contactCTA.available || "Available for new projects"}</span>
          </div>
          
          <h2 class="title-gradient" data-aos="fade-up">
            {i18n.contact.getInTouch}
          </h2>
          
          <p class="subtitle" data-aos="fade-up" data-aos-delay="100">
            {i18n.contact.contactDescription}
          </p>

          <!-- WhatsApp mis en avant ici -->
          <div class="highlight-box" data-aos="fade-up" data-aos-delay="200">
            <a href="https://wa.me/22997279001" target="_blank" rel="noopener noreferrer" class="info-card glass-item whatsapp-highlight magnetic-target">
              <div class="icon-box whatsapp-icon">
                <i class="fab fa-whatsapp"></i>
                <span class="pulse-ring"></span>
              </div>
              <div class="info-text">
                <div class="label-row">
                  <h5>WhatsApp</h5>
                  <span class="online-badge">Online</span>
                </div>
                <p>+229 97 27 90 01</p>
                <span class="chat-cta">Chat with me now <i class="fas fa-arrow-right"></i></span>
              </div>
            </a>
          </div>

          <div class="social-connect" data-aos="fade-up" data-aos-delay="300">
            <h5 class="social-title">{i18n.contact.followMe}</h5>
            <div class="social-links">
              <a href="https://github.com/ansetechnoapp" target="_blank" rel="noopener noreferrer" class="social-btn github magnetic-target" aria-label="GitHub">
                <i class="fab fa-github"></i>
              </a>
              <a href="https://www.linkedin.com/in/anscod/" target="_blank" rel="noopener noreferrer" class="social-btn linkedin magnetic-target" aria-label="LinkedIn">
                <i class="fab fa-linkedin-in"></i>
              </a>
              <a href="https://pinterest.com/anscoddesign" target="_blank" rel="noopener noreferrer" class="social-btn pinterest magnetic-target" aria-label="Pinterest">
                <i class="fab fa-pinterest"></i>
              </a>
              <a href="https://instagram.com/anscod.otty" target="_blank" rel="noopener noreferrer" class="social-btn instagram magnetic-target" aria-label="Instagram">
                <i class="fab fa-instagram"></i>
              </a>
            </div>
          </div>
        </div>

        <!-- Section Formulaire (Droite) -->
        <div class="contact-form-side" data-aos="fade-left" data-aos-delay="200">
          <form id="contact-form" class="premium-form">
            <div class="form-row">
              <div class="form-group">
                <label for="name">{i18n.contact.yourName}</label>
                <div class="input-wrapper">
                  <input type="text" id="name" name="name" required minlength="2" placeholder={i18n.contact.namePlaceholder} />
                  <div class="input-focus-bg"></div>
                </div>
                <span class="error-msg" id="name-error">{i18n.contact.errors.name}</span>
              </div>
              
              <div class="form-group">
                <label for="email">{i18n.contact.yourEmail}</label>
                <div class="input-wrapper">
                  <input type="email" id="email" name="email" required placeholder={i18n.contact.emailPlaceholder} />
                  <div class="input-focus-bg"></div>
                </div>
                <span class="error-msg" id="email-error">{i18n.contact.errors.email}</span>
              </div>
            </div>

            <div class="form-group">
              <label for="subject">{i18n.contact.subject}</label>
              <div class="input-wrapper">
                <input type="text" id="subject" name="subject" required placeholder={i18n.contact.subjectPlaceholder} />
                <div class="input-focus-bg"></div>
              </div>
              <span class="error-msg" id="subject-error">{i18n.contact.errors.subject}</span>
            </div>

            <div class="form-group">
              <label for="message">{i18n.contact.yourMessage}</label>
              <div class="input-wrapper">
                <textarea id="message" name="message" rows="5" required minlength="10" placeholder={i18n.contact.messagePlaceholder}></textarea>
                <div class="input-focus-bg"></div>
              </div>
              <span class="error-msg" id="message-error">{i18n.contact.errors.message}</span>
            </div>

            <button type="submit" id="submit-button" class="submit-btn magnetic-target">
              <span class="btn-text">{i18n.contact.sendMessage}</span>
              <span class="btn-icon"><i class="fas fa-paper-plane"></i></span>
              <div class="btn-glow"></div>
            </button>

            <div class="form-status" id="form-status">
              <div class="success-msg hidden">
                <i class="fas fa-check-circle"></i>
                <span>{i18n.contact.success}</span>
              </div>
            </div>
          </form>
        </div>

        <!-- Section Infos Bas (Pleine largeur) -->
        <div class="bottom-info-grid" data-aos="fade-up" data-aos-delay="400">
          <div class="info-card glass-item">
            <div class="icon-box email-icon">
              <i class="fas fa-envelope"></i>
            </div>
            <div class="info-text">
              <h5>{i18n.contact.email}</h5>
              <p>{dataUser.email}</p>
            </div>
          </div>

          <div class="info-card glass-item">
            <div class="icon-box location-icon">
              <i class="fas fa-map-marker-alt"></i>
            </div>
            <div class="info-text">
              <h5>{i18n.contact.location}</h5>
              <p>{i18n.contact.basedIn}</p>
            </div>
          </div>

          <div class="info-card glass-item">
            <div class="icon-box website-icon">
              <i class="fas fa-globe"></i>
            </div>
            <div class="info-text">
              <h5>{i18n.contact.website}</h5>
              <p>{dataUser.website}</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Floating WhatsApp Button -->
  <a href="https://wa.me/22997279001" target="_blank" rel="noopener noreferrer" class="whatsapp-fab magnetic-target" aria-label="Chat on WhatsApp">
    <i class="fab fa-whatsapp"></i>
    <span class="fab-tooltip">Chat with me</span>
    <div class="fab-glow"></div>
  </a>
</aside>

<style>
  /* Floating FAB Styles */
  .whatsapp-fab {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    width: 60px;
    height: 60px;
    background: #25d366;
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    box-shadow: 0 10px 25px rgba(37, 211, 102, 0.4);
    z-index: 999;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    text-decoration: none;
    opacity: 0;
    transform: scale(0) translateY(20px);
    pointer-events: none;
  }

  :global(.loaded) .whatsapp-fab {
    opacity: 1;
    transform: scale(1) translateY(0);
    pointer-events: auto;
  }

  .whatsapp-fab:hover {
    transform: scale(1.1) rotate(10deg);
    box-shadow: 0 15px 35px rgba(37, 211, 102, 0.6);
  }

  .fab-tooltip {
    position: absolute;
    right: 120%;
    background: rgba(0, 0, 0, 0.8);
    color: white;
    padding: 0.5rem 1rem;
    border-radius: 10px;
    font-size: 0.85rem;
    white-space: nowrap;
    opacity: 0;
    transform: translateX(10px);
    transition: all 0.3s ease;
    pointer-events: none;
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .whatsapp-fab:hover .fab-tooltip {
    opacity: 1;
    transform: translateX(0);
  }

  .fab-glow {
    position: absolute;
    inset: -10px;
    background: radial-gradient(circle, rgba(37, 211, 102, 0.3) 0%, transparent 70%);
    z-index: -1;
    animation: fab-glow 2s infinite;
  }

  @keyframes fab-glow {
    0%, 100% { transform: scale(1); opacity: 0.3; }
    50% { transform: scale(1.2); opacity: 0.6; }
  }

  @media (max-width: 640px) {
    .whatsapp-fab {
      bottom: 5rem; /* Éviter la barre de navigation mobile */
      right: 1.5rem;
      width: 50px;
      height: 50px;
      font-size: 1.5rem;
    }
  }

  .contact-cta-premium {
    position: relative;
    padding-block: 8rem;
    margin-block: 2rem;
    overflow: hidden;
    display: flex;
    justify-content: center;
    align-items: center;
    perspective: 1500px;
  }

  .bg-noise {
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
    opacity: 0.05;
    z-index: 1;
    pointer-events: none;
  }

  .background-blobs {
    position: absolute;
    inset: 0;
    z-index: 0;
    filter: blur(100px);
  }

  .blob {
    position: absolute;
    border-radius: 50%;
    opacity: 0.15;
    animation: float 20s infinite alternate ease-in-out;
  }

  .blob-1 { top: 10%; right: 20%; width: 600px; height: 600px; background: var(--accent-light); }
  .blob-2 { bottom: 10%; left: 15%; width: 500px; height: 500px; background: var(--accent-secondary); animation-delay: -5s; }
  .blob-3 { top: 40%; left: 40%; width: 300px; height: 300px; background: #4facfe; animation-delay: -10s; }

  @keyframes float {
    0% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(30px, -50px) scale(1.1); }
    66% { transform: translate(-20px, 20px) scale(0.9); }
    100% { transform: translate(0, 0) scale(1); }
  }

  .premium-card-wrapper {
    width: 100%;
    max-width: 1200px;
    margin-inline: 1.5rem;
    transition: transform 5s ease-out;
    z-index: 2;
  }

  .premium-container {
    position: relative;
    padding: 4rem;
    background: rgba(var(--gray-999-basis), 0.5);
    backdrop-filter: blur(30px);
    -webkit-backdrop-filter: blur(30px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 32px;
    overflow: hidden;
    box-shadow: 0 40px 100px -20px rgba(0, 0, 0, 0.4);
  }

  .spotlight {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      800px circle at var(--x, 50%) var(--y, 50%),
      rgba(var(--accent-light-rgb, 157, 78, 255), 0.08),
      transparent 40%
    );
    z-index: 1;
    pointer-events: none;
  }

  .card-glass-shine {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.05) 0%, transparent 50%, rgba(255, 255, 255, 0.01) 100%);
    pointer-events: none;
    z-index: 1;
  }

  .content-grid {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
  }

  @media (min-width: 64em) {
    .content-grid {
      grid-template-columns: 0.9fr 1.1fr;
      gap: 5rem;
    }
  }

  /* Bottom Row Styling */
  .bottom-info-grid {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  @media (min-width: 48em) {
    .bottom-info-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* Contact Info Side */
  .status-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: rgba(var(--accent-light-rgb, 157, 78, 255), 0.1);
    border: 1px solid rgba(var(--accent-light-rgb, 157, 78, 255), 0.2);
    border-radius: 100px;
    margin-bottom: 1.5rem;
    color: var(--accent-light);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .dot { width: 8px; height: 8px; background: var(--accent-light); border-radius: 50%; box-shadow: 0 0 10px var(--accent-light); animation: blink 2s infinite; }
  @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }

  .title-gradient {
    font-size: clamp(2rem, 5vw, 3rem);
    font-family: var(--font-display);
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 1.5rem;
    background: linear-gradient(to bottom right, var(--gray-0) 0%, var(--gray-200) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .subtitle {
    font-size: 1.1rem;
    color: var(--gray-200);
    line-height: 1.6;
    margin-bottom: 2rem;
  }

  .highlight-box {
    margin-bottom: 3rem;
  }

  .info-card {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1.25rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 20px;
    transition: all 0.3s ease;
    text-decoration: none;
  }

  .info-card:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.1);
    transform: translateX(5px);
  }

  /* WhatsApp Highlight */
  .whatsapp-highlight {
    background: rgba(37, 211, 102, 0.05) !important;
    border: 1px solid rgba(37, 211, 102, 0.2) !important;
  }

  .whatsapp-highlight:hover {
    background: rgba(37, 211, 102, 0.1) !important;
    border-color: rgba(37, 211, 102, 0.4) !important;
    box-shadow: 0 15px 30px rgba(37, 211, 102, 0.15);
  }

  .whatsapp-icon { 
    background: rgba(37, 211, 102, 0.2) !important; 
    color: #25d366 !important;
    position: relative;
  }

  .pulse-ring {
    position: absolute;
    width: 100%;
    height: 100%;
    border: 2px solid #25d366;
    border-radius: inherit;
    animation: pulse-ring 2s cubic-bezier(0.455, 0.03, 0.515, 0.955) infinite;
  }

  @keyframes pulse-ring {
    0% { transform: scale(0.8); opacity: 0.5; }
    80%, 100% { transform: scale(1.5); opacity: 0; }
  }

  .label-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.25rem;
  }

  .online-badge {
    font-size: 0.65rem;
    padding: 0.1rem 0.5rem;
    background: rgba(37, 211, 102, 0.2);
    color: #25d366;
    border-radius: 100px;
    font-weight: 700;
    text-transform: uppercase;
  }

  .chat-cta {
    display: block;
    font-size: 0.8rem;
    color: #25d366;
    font-weight: 600;
    margin-top: 0.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .chat-cta i {
    transition: transform 0.3s ease;
  }

  .whatsapp-highlight:hover .chat-cta i {
    transform: translateX(5px);
  }

  .icon-box {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 14px;
    font-size: 1.25rem;
  }

  .email-icon { background: rgba(59, 130, 246, 0.1); color: #3b82f6; }
  .phone-icon { background: rgba(99, 102, 241, 0.1); color: #6366f1; }
  .location-icon { background: rgba(168, 85, 247, 0.1); color: #a855f7; }
  .website-icon { background: rgba(34, 197, 94, 0.1); color: #22c55e; }

  .info-text h5 { font-size: 0.9rem; margin-bottom: 0.25rem; color: var(--gray-200); }
  .info-text p { font-size: 1rem; color: var(--gray-200); margin: 0; }

  /* Social Connect */
  .social-title { font-size: 1rem; margin-bottom: 1.25rem; color: var(--gray-300); }
  .social-links { display: flex; gap: 1rem; }
  .social-btn {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    color: var(--gray-400);
    transition: all 0.3s ease;
    font-size: 1.2rem;
  }

  .social-btn:hover {
    background: var(--accent-light);
    color: white;
    transform: translateY(-5px);
    box-shadow: 0 10px 20px rgba(var(--accent-light-rgb, 157, 78, 255), 0.3);
  }

  /* Form Side */
  .premium-form { display: grid; gap: 1.5rem; }
  .form-row { display: grid; grid-template-columns: 1fr; gap: 1.5rem; }
  @media (min-width: 40em) { .form-row { grid-template-columns: 1fr 1fr; } }

  .form-group { display: grid; gap: 0.5rem; }
  .form-group label { font-size: 0.9rem; font-weight: 600; color: var(--gray-200); margin-left: 0.5rem; }

  .input-wrapper { position: relative; }
  
  input, textarea {
    width: 100%;
    padding: 1rem 1.25rem;
    background: rgba(var(--gray-999-basis), 0.05);
    border: 1px solid rgba(var(--gray-999-basis), 0.1);
    border-radius: 16px;
    color: var(--gray-0);
    font-family: inherit;
    font-size: 1rem;
    transition: all 0.3s ease;
    outline: none;
  }

  input::placeholder, textarea::placeholder {
    color: var(--gray-400);
    opacity: 0.7;
  }

  input:focus, textarea:focus {
    background: rgba(var(--gray-999-basis), 0.08);
    border-color: var(--accent-light);
    box-shadow: 0 0 0 4px rgba(var(--accent-light-rgb, 157, 78, 255), 0.1);
  }

  .error-msg { font-size: 0.8rem; color: #ef4444; margin-left: 0.5rem; display: none; }
  input:invalid:not(:placeholder-shown) ~ .error-msg { display: block; }

  .submit-btn {
    position: relative;
    padding: 1.25rem;
    margin-top: 1rem;
    background: linear-gradient(135deg, var(--accent-light) 0%, var(--accent-regular) 100%);
    border: none;
    border-radius: 16px;
    color: white;
    font-weight: 700;
    font-size: 1.1rem;
    cursor: pointer;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    transition: all 0.3s ease;
  }

  .submit-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 15px 30px rgba(var(--accent-light-rgb, 157, 78, 255), 0.4);
  }

  .submit-btn:active { transform: translateY(0); }

  .btn-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at var(--bx, 50%) var(--by, 50%), rgba(255,255,255,0.3) 0%, transparent 60%);
    opacity: 0;
    transition: opacity 0.3s;
    pointer-events: none;
  }

  .submit-btn:hover .btn-glow { opacity: 1; }

  .success-msg {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem;
    background: rgba(34, 197, 94, 0.1);
    border: 1px solid rgba(34, 197, 94, 0.2);
    border-radius: 12px;
    color: #4ade80;
    margin-top: 1.5rem;
  }

  .hidden { display: none; }

  @media (max-width: 480px) {
    .premium-container { padding: 3rem 1.5rem; border-radius: 24px; }
    .title-gradient { font-size: 2.25rem; }
  }
</style>

<script>
  function initContactEffects() {
    const cardWrapper = document.getElementById('premium-card');
    const container = cardWrapper?.querySelector('.premium-container') as HTMLElement;
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const submitBtn = document.getElementById('submit-button') as HTMLButtonElement;
    const statusDiv = document.getElementById('form-status');
    const magneticTargets = document.querySelectorAll('.magnetic-target');

    if (!cardWrapper || !container) return;

    // 3D Tilt and Spotlight
    cardWrapper.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = cardWrapper.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;

      container.style.setProperty('--x', `${x}px`);
      container.style.setProperty('--y', `${y}px`);

      const centerX = rect.width / 2;
      const centerY = rect.height / 2;
      const rotateX = (y - centerY) / 40;
      const rotateY = (centerX - x) / 40;

      cardWrapper.style.transform = `rotateX(${rotateX}deg) rotateY(${rotateY}deg)`;
    });

    cardWrapper.addEventListener('mouseleave', () => {
      cardWrapper.style.transform = 'rotateX(0deg) rotateY(0deg)';
    });

    // Magnetic Effects
    magneticTargets.forEach((target) => {
      target.addEventListener('mousemove', (e: any) => {
        const rect = target.getBoundingClientRect();
        const x = e.clientX - rect.left - rect.width / 2;
        const y = e.clientY - rect.top - rect.height / 2;
        
        (target as HTMLElement).style.transform = `translate(${x * 0.15}px, ${y * 0.15}px)`;
        
        if (target === submitBtn) {
           submitBtn.style.setProperty('--bx', `${e.clientX - rect.left}px`);
           submitBtn.style.setProperty('--by', `${e.clientY - rect.top}px`);
        }
      });

      target.addEventListener('mouseleave', () => {
        (target as HTMLElement).style.transform = `translate(0, 0)`;
      });
    });

    // Form Submission
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const formData = new FormData(form);
      
      // Animation Loading
      const originalContent = submitBtn.innerHTML;
      submitBtn.disabled = true;
      submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Sending...';

      try {
        // Simulation d'envoi (Remplacer par un vrai fetch si nécessaire)
        await new Promise(resolve => setTimeout(resolve, 1500));
        
        statusDiv?.querySelector('.success-msg')?.classList.remove('hidden');
        form.reset();
        
        setTimeout(() => {
           statusDiv?.querySelector('.success-msg')?.classList.add('hidden');
        }, 5000);
      } catch (error) {
        console.error('Error sending message:', error);
      } finally {
        submitBtn.disabled = false;
        submitBtn.innerHTML = originalContent;
      }
    });
  }

  document.addEventListener('astro:page-load', initContactEffects);
  initContactEffects();
</script>
